# ─────────────────────────────────────────────────────────────
#  AI Software Engineering Team — Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── LLM (Required) ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# Optional LLM overrides
# MODEL_NAME=gpt-4o
# TEMPERATURE=0.2
# MAX_TOKENS=4096

# ── LangSmith Observability (Optional but strongly recommended) ────
#
# Sign up at https://smith.langchain.com
# Create an API key under Settings → API Keys
# Tracing is automatically ENABLED when LANGSMITH_API_KEY is set.
#
LANGSMITH_API_KEY=lsv2_your-key-here
LANGSMITH_PROJECT=ai-software-team
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_TRACING_V2=true    # set to "false" to disable tracing

# ── Server ────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# ── Reliability ───────────────────────────────────────────────
MAX_RETRIES=3

# ── PostgreSQL (used by docker-compose) ──────────────────────
# POSTGRES_USER=ai_team
# POSTGRES_PASSWORD=supersecretpassword
# POSTGRES_DB=agent_state

# ── Redis (used by docker-compose) ───────────────────────────
# REDIS_URL=redis://localhost:6379/0

