# AI Software Engineering Team — Configuration
# Copy this file to `.env` and fill in values.

# OpenAI (or compatible) API key — required for agent LLM calls in later chunks
OPENAI_API_KEY=sk-your-key-here

# LangSmith tracing (optional but recommended for debugging)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-software-team

# Server
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# Retry defaults
MAX_RETRIES=3
